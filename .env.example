# === Required: Grok Search ===
# Option A: Use grok2api (shared access)
GROK_API_URL=https://your-grok2api-endpoint/v1
GROK_API_KEY=your-grok2api-key

# Option B: Use xAI directly
# GROK_API_URL=https://api.x.ai/v1
# GROK_API_KEY=xai-your-key

# Option C: Use GuDa (all-in-one)
# GUDA_API_KEY=your-guda-key

# === Optional: Tavily ===
# Use Tavily pool (shared) or official API
TAVILY_API_URL=https://api.tavily.com
TAVILY_API_KEY=tvly-your-key

# === Optional: Exa (semantic search) ===
EXA_API_KEY=your-exa-key

# === Optional: Firecrawl (fallback) ===
# FIRECRAWL_API_URL=https://api.firecrawl.dev/v2
# FIRECRAWL_API_KEY=your-firecrawl-key
